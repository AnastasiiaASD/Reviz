# ─── Jira / Confluence auth (shared token) ─────────────────────────────────
# JSON object with host, email, and API token.
# Example: {"host":"https://yourorg.atlassian.net","email":"you@example.com","token":"ATATT..."}
JIRA_JSON=

# ─── GitHub ─────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow scopes (used to clone/push QA repo and create PRs)
GH_TOKEN=

# ─── OpenCode ───────────────────────────────────────────────────────────────
OPENCODE_API_KEY=

# ─── Tests repository ───────────────────────────────────────────────────────
TESTS_REPO_OWNER=
TESTS_REPO_NAME=revyoos-qa-automation

# ─── Runtime ────────────────────────────────────────────────────────────────
# RUN_MODE: webhook (default) | cron | loop
RUN_MODE=webhook
PORT=8080
# Required only in webhook mode to protect the /run endpoint
TRIGGER_SECRET=

# ─── Confluence ─────────────────────────────────────────────────────────────
CONFLUENCE_SPACE_KEY=QA
CONFLUENCE_PARENT_PAGE_ID=
